<w:document xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:mo="http://schemas.microsoft.com/office/mac/office/2008/main" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:mv="urn:schemas-microsoft-com:mac:vml" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" mc:Ignorable="w14 wp14"><w:body><w:p><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>Death Wheel Roguelike – UI Layout Design</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Core Layout Structure</w:t></w:r></w:p><w:p><w:r><w:t>Top: Run Info Bar (Spins, Cash, Risk, Lives)</w:t></w:r></w:p><w:p><w:r><w:t>Center: Large Wheel (dominant element, ~60–70% width)</w:t></w:r></w:p><w:p><w:r><w:t>Below Wheel: Spin Button (large, glowing)</w:t></w:r></w:p><w:p><w:r><w:t>Bottom Left: Effects Panel (buffs and curses)</w:t></w:r></w:p><w:p><w:r><w:t>Bottom Right: Event Log (recent spin results)</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Wheel Design</w:t></w:r></w:p><w:p><w:r><w:t>The wheel must be the largest element on screen.</w:t></w:r></w:p><w:p><w:r><w:t>Pointer fixed at top, wheel spins beneath it.</w:t></w:r></w:p><w:p><w:r><w:t>High-contrast segment colors:</w:t></w:r></w:p><w:p><w:r><w:t>Normal – dark gray</w:t></w:r></w:p><w:p><w:r><w:t>Lucky – gold</w:t></w:r></w:p><w:p><w:r><w:t>Death – deep red</w:t></w:r></w:p><w:p><w:r><w:t>Chaos – purple</w:t></w:r></w:p><w:p><w:r><w:t>Multiplier – blue</w:t></w:r></w:p><w:p><w:r><w:t>Shield – cyan</w:t></w:r></w:p><w:p><w:r><w:t>Curse – green</w:t></w:r></w:p><w:p><w:r><w:t>Shop – orange</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Spin Button</w:t></w:r></w:p><w:p><w:r><w:t>Large and centered below the wheel.</w:t></w:r></w:p><w:p><w:r><w:t>Color changes with risk level:</w:t></w:r></w:p><w:p><w:r><w:t>Low risk – blue</w:t></w:r></w:p><w:p><w:r><w:t>Medium risk – orange</w:t></w:r></w:p><w:p><w:r><w:t>High risk – red</w:t></w:r></w:p><w:p><w:r><w:t>Button should pulse slightly to attract attention.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Run Info Bar</w:t></w:r></w:p><w:p><w:r><w:t>Displays current run status:</w:t></w:r></w:p><w:p><w:r><w:t>Cash</w:t></w:r></w:p><w:p><w:r><w:t>Spin count</w:t></w:r></w:p><w:p><w:r><w:t>Risk level</w:t></w:r></w:p><w:p><w:r><w:t>Lives remaining</w:t></w:r></w:p><w:p/><w:p><w:r><w:t>Numbers animate when values change to create tension.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Effects Panel</w:t></w:r></w:p><w:p><w:r><w:t>Shows active buffs and curses using icons and short labels.</w:t></w:r></w:p><w:p><w:r><w:t>Examples:</w:t></w:r></w:p><w:p><w:r><w:t>Shield</w:t></w:r></w:p><w:p><w:r><w:t>x2 Multiplier</w:t></w:r></w:p><w:p><w:r><w:t>Fragile Curse</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Event Log</w:t></w:r></w:p><w:p><w:r><w:t>Displays the last few spins and events.</w:t></w:r></w:p><w:p><w:r><w:t>Example:</w:t></w:r></w:p><w:p><w:r><w:t>Spin 12 → Lucky +120</w:t></w:r></w:p><w:p><w:r><w:t>Spin 13 → Chaos: Wheel Shuffle</w:t></w:r></w:p><w:p><w:r><w:t>Spin 14 → Death -80</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Intensity Effects</w:t></w:r></w:p><w:p><w:r><w:t>Screen shake when Death lands.</w:t></w:r></w:p><w:p><w:r><w:t>Slow motion during final part of wheel spin.</w:t></w:r></w:p><w:p><w:r><w:t>Strong sound effects when the wheel stops.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Color Style</w:t></w:r></w:p><w:p><w:r><w:t>Use a dark background (#0f0f14) with glowing accent colors.</w:t></w:r></w:p><w:p><w:r><w:t>Panels slightly lighter (#1a1a22).</w:t></w:r></w:p><w:p><w:r><w:t>Gold and red highlights should feel dramatic.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t>Mobile Layout</w:t></w:r></w:p><w:p><w:r><w:t>Top: Run Info</w:t></w:r></w:p><w:p><w:r><w:t>Middle: Wheel</w:t></w:r></w:p><w:p><w:r><w:t>Below: Spin Button</w:t></w:r></w:p><w:p><w:r><w:t>Bottom: Effects and Event Log</w:t></w:r></w:p><w:sectPr w:rsidR="00FC693F" w:rsidRPr="0006063C" w:rsidSect="00034616"><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="1440" w:right="1800" w:bottom="1440" w:left="1800" w:header="720" w:footer="720" w:gutter="0"/><w:cols w:space="720"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>